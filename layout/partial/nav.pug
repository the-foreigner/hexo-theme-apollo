ul(class="list-none m-0 p-0 flex flex-wrap justify-center sm:justify-end")
    each value, key in theme.menu
        - var re = /^(http|https):\/\/*/gi;
        - var tar = re.test(value) ? "_blank" : "_self"
        - var act = !re.test(value) && "/"+page.current_url === value
        li(class="px-2.5 py-2.5 sm:py-[19px]")
            a.nav-list-link(class={active: act} href=url_for(value) target=tar class="text-base leading-[1.4]")
                != key.toUpperCase()
