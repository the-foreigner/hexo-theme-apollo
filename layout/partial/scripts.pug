//- Google Analytics 4
- var ga = theme.ga
if ga
    script(async src="https://www.googletagmanager.com/gtag/js?id=" + ga)
    script.
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', '#{ga}');
